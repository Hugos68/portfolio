/*place global styles here */
html, body { 
    @apply h-full overflow-hidden; 
}

:root {
    --header-height: 5.5rem;
}

body:not(body > *), 
.footer,
.app-bar, 
h1, 
h2, 
h3, 
a, 
p, 
span, 
label {
    @apply text-token transition-colors;
}

.page {
    @apply px-4 pb-16 container mx-auto h-full min-h-[calc(100vh-var(--header-height))];
}

.skills-devicon {
    @apply aspect-square text-[clamp(3rem,5vw,5rem)];
}
