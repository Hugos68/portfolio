/*place global styles here */
html, body { 
    @apply h-full overflow-hidden; 
}

:root {
    --header-height: 5rem;
}

.base-page-container {
    @apply h-full min-h-[calc(100vh-var(--header-height))] container mx-auto px-4 pb-12;
}

.skills-devicon {
    @apply aspect-square text-[clamp(3rem,5vw,5rem)];
}

.blink {
    animation: blink 1s step-start infinite;
}
  
@keyframes blink {
    50% {
        opacity: 0;
    }
}